rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Modelo "social" (entre amigos): leitura e escrita abertas, igual ao que já era.
    // Para travar de verdade (cada um só edita a própria ficha), exigir request.auth
    // com login do Firebase Authentication no futuro.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
